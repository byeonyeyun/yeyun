# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=CHANGE_ME_generate_random_secret_key
COOKIE_DOMAIN=localhost
FRONTEND_ORIGIN=http://localhost:5173

# ai-worker
AI_WORKER_VERSION=v1.0.0

# db
DB_HOST=localhost
DB_PORT=3306
DB_EXPOSE_PORT=3306
DB_USER=ozcoding
DB_PASSWORD=CHANGE_ME_db_password
DB_ROOT_PASSWORD=CHANGE_ME_db_root_password
DB_NAME=ai_health

# redis (로컬 실행 시 127.0.0.1, docker compose 내부에서는 redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_SOCKET_TIMEOUT_SECONDS=2

# ocr
OCR_QUEUE_KEY=ocr:jobs
OCR_RETRY_QUEUE_KEY=ocr:jobs:retry
OCR_DEAD_LETTER_QUEUE_KEY=ocr:jobs:dead-letter
OCR_RETRY_BACKOFF_BASE_SECONDS=5
OCR_RETRY_BACKOFF_MAX_SECONDS=60
OCR_RETRY_RELEASE_BATCH_SIZE=100
OCR_JOB_MAX_RETRIES=3

# guide
GUIDE_QUEUE_KEY=guide:jobs
GUIDE_JOB_MAX_RETRIES=3

# openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_GUIDE_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# clova ocr
CLOVA_OCR_APIGW_URL=
CLOVA_OCR_SECRET=

# rag / chromadb (로컬 실행 시 127.0.0.1, docker compose 내부에서는 chromadb)
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
CHROMA_COLLECTION=adhd_knowledge
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.4
RAG_BM25_WEIGHT=0.3
